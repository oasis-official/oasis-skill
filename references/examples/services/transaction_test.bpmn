<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
                  id="Definitions_transaction_test"
                  targetNamespace="http://bpmn.io/schema/bpmn">
  <!--
    Pattern: a single transaction spans the whole BPMN.
      - DML script tasks must use the `insert,` / `update,` resource prefix.
      - Inside the multi-instance loop, each iteration's SELECT (mybatis) sees
        the prior iteration's flushed JPA writes because they share the same tx.
      - Inline SQL is also supported via <bpmn:script> with `[0]['col']->alias`.
  -->
  <bpmn:process id="transaction_test" isExecutable="true">
    <bpmn:startEvent id="start">
      <bpmn:outgoing>fStart</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:scriptTask id="loadTargets"
                     name="load target list"
                     scriptFormat="sql"
                     camunda:resource="transaction.list">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="output" value="targets" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:incoming>fStart</bpmn:incoming>
      <bpmn:outgoing>fLoaded</bpmn:outgoing>
    </bpmn:scriptTask>

    <bpmn:scriptTask id="seedRow"
                     name="seed row (DML)"
                     scriptFormat="sql"
                     camunda:resource="insert,transaction.new">
      <bpmn:incoming>fLoaded</bpmn:incoming>
      <bpmn:outgoing>fSeeded</bpmn:outgoing>
    </bpmn:scriptTask>

    <bpmn:subProcess id="loop" name="loop">
      <bpmn:multiInstanceLoopCharacteristics isSequential="true"
                                             camunda:collection="targets"
                                             camunda:elementVariable="id" />
      <bpmn:incoming>fSeeded</bpmn:incoming>
      <bpmn:outgoing>fLoopDone</bpmn:outgoing>

      <bpmn:startEvent id="loopStart">
        <bpmn:outgoing>fInner1</bpmn:outgoing>
      </bpmn:startEvent>

      <bpmn:scriptTask id="readMax"
                       name="read max via mybatis"
                       scriptFormat="sql"
                       camunda:resource="transaction.max">
        <bpmn:extensionElements>
          <camunda:properties>
            <camunda:property name="output" value="[0]['maxAge']->maxAge" />
          </camunda:properties>
        </bpmn:extensionElements>
        <bpmn:incoming>fInner1</bpmn:incoming>
        <bpmn:outgoing>fInner2</bpmn:outgoing>
      </bpmn:scriptTask>

      <bpmn:serviceTask id="appendRow"
                        name="append row (JPA)"
                        camunda:class="integration.TransactionTest$Consumer#incAge">
        <bpmn:incoming>fInner2</bpmn:incoming>
        <bpmn:outgoing>fInner3</bpmn:outgoing>
      </bpmn:serviceTask>

      <bpmn:endEvent id="loopEnd">
        <bpmn:incoming>fInner3</bpmn:incoming>
      </bpmn:endEvent>

      <bpmn:sequenceFlow id="fInner1" sourceRef="loopStart" targetRef="readMax" />
      <bpmn:sequenceFlow id="fInner2" sourceRef="readMax"   targetRef="appendRow" />
      <bpmn:sequenceFlow id="fInner3" sourceRef="appendRow" targetRef="loopEnd" />
    </bpmn:subProcess>

    <!-- alternate technique: inline SQL pulling a single column via PropertyEL -->
    <bpmn:scriptTask id="readMaxInline"
                     name="read max inline"
                     scriptFormat="sql">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="output" value="[0]['maxAge']->maxAge" />
        </camunda:properties>
      </bpmn:extensionElements>
      <bpmn:script>select nvl(max(age), 0) as maxAge from SAMPLE_TABLE</bpmn:script>
    </bpmn:scriptTask>

    <!-- alternate technique: JPA-backed read returning List<Map> -->
    <bpmn:serviceTask id="readMaxJpa"
                      name="read max via JPA"
                      camunda:class="integration.TransactionTest$Consumer#getMax">
      <bpmn:extensionElements>
        <camunda:properties>
          <camunda:property name="output" value="[0]['maxAge']->maxAge" />
        </camunda:properties>
      </bpmn:extensionElements>
    </bpmn:serviceTask>

    <bpmn:endEvent id="end">
      <bpmn:incoming>fLoopDone</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="fStart"    sourceRef="start"       targetRef="loadTargets" />
    <bpmn:sequenceFlow id="fLoaded"   sourceRef="loadTargets" targetRef="seedRow" />
    <bpmn:sequenceFlow id="fSeeded"   sourceRef="seedRow"     targetRef="loop" />
    <bpmn:sequenceFlow id="fLoopDone" sourceRef="loop"        targetRef="end" />
  </bpmn:process>
</bpmn:definitions>
