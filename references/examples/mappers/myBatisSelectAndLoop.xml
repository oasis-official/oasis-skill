<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.apache.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="test">
    <resultMap id="selectBindResultMap" type="map">
        <result column="age" property="age" javaType="int" />
    </resultMap>
    <select id="selectIdsAsMap" resultType="map">
        <![CDATA[
            select '1' as id from dual union all
            select '2' as id from dual
        ]]>
    </select>
    <select id="selectBind" resultMap="selectBindResultMap">
        <![CDATA[
        select #{id} as id, 123 as age from dual
        ]]>
    </select>
</mapper>
